---
import { getBlogs, getBlogDetail } from "../../library/microcms";

export async function getStaticPaths() {
  const response = await getBlogs({ fields: ["id"] });
  return response.contents.map((blog) => ({
    params: { id: blog.id },
  }));
}

const { id } = Astro.params;
const blog = await getBlogDetail(id as string);
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <title>{blog.title}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
      body { font-family: sans-serif; max-width: 800px; margin: 0 auto; padding: 20px; line-height: 1.6; }
      h1 { border-bottom: 2px solid #333; padding-bottom: 10px; }
      .date { color: #666; font-size: 0.9rem; }
      .content { margin-top: 20px; }
    </style>
  </head>
  <body>
    <a href="/">← 一覧に戻る</a>
    <h1>{blog.title}</h1>
    <p class="date">公開日: {new Date(blog.publishedAt).toLocaleDateString('ja-JP')}</p>
    <div class="content" set:html={blog.content} />
  </body>
</html>